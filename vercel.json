{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npx turbo run build --filter=@grspecials/web",
  "outputDirectory": ".next",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/expire-deals",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-r2",
      "schedule": "0 3 * * 0"
    }
  ]
}
